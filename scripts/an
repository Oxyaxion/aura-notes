#!/usr/bin/env bash
# an — Aura Notes CLI
# Commands: ls, get <name>, put <name>, rm <name>, query <q>, search <q>, key
# Config:   AN_URL (default: http://localhost:3000)
#           AN_KEY or AURA_NOTES_KEY

set -euo pipefail

AN_URL="${AN_URL:-${AURA_NOTES_URL:-http://localhost:3000}}"
AN_KEY="${AN_KEY:-${AURA_NOTES_KEY:-}}"

auth_args=()
[[ -n "$AN_KEY" ]] && auth_args+=(-H "Authorization: Bearer $AN_KEY")

BOLD=$'\e[1m'
DIM=$'\e[2m'
RESET=$'\e[0m'

# Encode each path segment individually so / is preserved as separator
urlencode() {
    printf '%s' "$1" | jq -Rr 'split("/") | map(@uri) | join("/")'
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

  ls|list)
    result=$(curl -sf "${auth_args[@]}" "$AN_URL/notes")
    echo "$result" | jq -r '.[] | (if .pinned then "★" else " " end) + " " + .name'
    echo ""
    echo "$result" | jq -r '(length|tostring) + " notes"'
    ;;

  get|cat|read)
    [[ -z "${1:-}" ]] && { echo "Usage: an get <name>"; exit 1; }
    name="$(urlencode "$1")"
    curl -sf "${auth_args[@]}" "$AN_URL/notes/$name" | jq -r '.content // ""'
    ;;

  put|write|save)
    [[ -z "${1:-}" ]] && { echo "Usage: an put <name> < file.md"; exit 1; }
    name="$(urlencode "$1")"
    content="$(cat)"
    # --arg handles newlines and special chars safely
    payload=$(jq -Rn --arg c "$content" '{"content": $c}')
    curl -sf -X PUT "${auth_args[@]}" \
      -H "Content-Type: application/json" \
      -d "$payload" \
      "$AN_URL/notes/$name"
    echo "Saved: $1"
    ;;

  rm|delete|del)
    [[ -z "${1:-}" ]] && { echo "Usage: an rm <name>"; exit 1; }
    name="$(urlencode "$1")"
    curl -sf -X DELETE "${auth_args[@]}" "$AN_URL/notes/$name"
    echo "Deleted: $1"
    ;;

  query|q)
    [[ -z "${1:-}" ]] && { echo "Usage: an query '<DSL>'"; exit 1; }
    q="$(urlencode "$1")"
    result=$(curl -sf "${auth_args[@]}" "$AN_URL/api/query?q=$q")
    echo "$result" | jq -r --arg dim "$DIM" --arg reset "$RESET" '
      .[] |
      (.title // .name) as $title |
      ( [ (.tags // [] | join(", ")),
          (.status // ""),
          (.date   // ""),
          (.area   // "") ]
        | map(select(. != ""))
        | join(" · ") ) as $meta |
      $title,
      if $meta != "" then "  " + $dim + $meta + $reset else empty end
    '
    echo ""
    echo "$result" | jq -r --arg dim "$DIM" --arg reset "$RESET" \
      '"" + $dim + (length|tostring) + " result(s)" + $reset'
    ;;

  search|s)
    [[ -z "${1:-}" ]] && { echo "Usage: an search '<text>'"; exit 1; }
    q="$(urlencode "$1")"
    result=$(curl -sf "${auth_args[@]}" "$AN_URL/api/search?q=$q")
    echo "$result" | jq -r --arg bold "$BOLD" --arg dim "$DIM" --arg reset "$RESET" '
      .[] |
      $bold + (.title // .name) + $reset,
      "  " + (.snippet // ""),
      ""
    '
    echo "$result" | jq -r --arg dim "$DIM" --arg reset "$RESET" \
      '$dim + (length|tostring) + " result(s)" + $reset'
    ;;

  key)
    curl -sf "${auth_args[@]}" "$AN_URL/api/key" \
      | jq -r '"API: " + (.api_key // "(not set)"), "MCP: " + (.mcp_key // "(not set)")'
    ;;

  help|--help|-h|'')
    cat <<'EOF'
an — Aura Notes CLI

Usage: an <command> [args]

Commands:
  ls                    List all notes (★ = pinned)
  get  <name>           Print note content
  put  <name>           Create/overwrite note from stdin
  rm   <name>           Delete a note
  query '<q>'           DSL query  (#tag, status:x, area:y, recent:10 …)
  search '<text>'       Full-text search
  key                   Show API and MCP keys

Config (env vars):
  AN_URL    Backend URL   (default: http://localhost:3000)
  AN_KEY    API key       (fallback: AURA_NOTES_KEY)

Examples:
  an ls
  an get "Dev/Rust - lifetimes"
  echo "# Hello" | an put "scratch"
  an query "#rust status:active"
  an search "ownership"
EOF
    ;;

  *)
    echo "Unknown command: $cmd  (try: an help)" >&2
    exit 1
    ;;
esac
